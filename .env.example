# code-intel-mcp environment configuration
# Copy this file to .env and fill in your values

# Joern CLI installation path
JOERN_CLI_PATH=/opt/joern/joern-cli

# ArangoDB connection
ARANGO_HOST=http://localhost:8529
ARANGO_USER=root
ARANGO_PASS=code_intel_dev
ARANGO_DB=code_intel

# Streamable HTTP transport (production mode — survives parent death)
# If set, the server runs as an HTTP server instead of stdio.
# Gateway config should use "type: remote" with "url: http://127.0.0.1:<port>/mcp"
# Omit this to use stdio transport (default, for CLI use)
# STREAMABLE_HTTP_PORT=3001